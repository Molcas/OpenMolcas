*-------------------------------------------------------------------------------
* Molecule: CH2=NH2+
* Basis: 3-21G
* Symmetry: C1
* Features tested: Tully Surface Hop with CASPT2
* Responsible people: Ignacio Fdez. Galván
* Comments: Three hopping versions, all should use JOBMIX instead of JOBIPH
*-------------------------------------------------------------------------------

>> export MOLCAS_MAXITER=5

* Simple HOP keyword

&GATEWAY
  Coord = init.xyz
  Basis = 3-21G
  Group = NoSym
  RICD

>> copy velocity.xyz $Project.velocity.xyz
>> do while

&SEWARD

&RASSCF
  NActEL = 4
  Charge = +1
  RAS2 = 4
  StAverage = 3
  MDRlxRoot = 2

&CASPT2
  RMult = all
  IPEA = 0.0
  Imaginary = 0.1

&ALASKA

&DYNAMIX
  VelVerlet
  dt = 20
  Velocities = 1
  Hop = 1

>> end do

* Tully surface hop (CI overlaps)

&GATEWAY
  Coord = init.xyz
  Basis = 3-21G
  Group = NoSym
  RICD

>> copy velocity.xyz $Project.velocity.xyz
>> do while

&SEWARD

&RASSCF
  NActEL = 4
  Charge = +1
  RAS2 = 4
  StAverage = 3
  MDRlxRoot = 2

&CASPT2
  RMult = all
  IPEA = 0.0
  Imaginary = 0.1

&SURFACEHOP
  Tully
  Decoherence = 0.1
  Substeps = 10
  FRand = 0.05
  NoRASSI

&ALASKA

&DYNAMIX
  VelVerlet
  dt = 20
  Velocities = 1

>> end do

* Tully surface hop (RASSI overlaps)

&GATEWAY
  Coord = init.xyz
  Basis = 3-21G
  Group = NoSym
  RICD

>> copy velocity.xyz $Project.velocity.xyz
>> do while

&SEWARD

&RASSCF
  NActEL = 4
  Charge = +1
  RAS2 = 4
  StAverage = 3
  MDRlxRoot = 2

&CASPT2
  RMult = all
  IPEA = 0.0
  Imaginary = 0.1

&SURFACEHOP
  Tully
  Decoherence = 0.1
  Substeps = 10
  FRand = 0.05

&ALASKA

&DYNAMIX
  VelVerlet
  dt = 20
  Velocities = 1

>> end do

