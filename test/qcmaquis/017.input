*-------------------------------------------------------------------------------
* Molecule: C2H2
* Basis: cc-pVDZ
* Symmetry: C1
* Features tested: MPSSI crash reproducer -- faithful translation of the exact
*                  workflow reported in qcscine/qcmaquis#36
* Responsible person: J. Schee
* Comments: CAS(4,4), CIROOT=3 3 1 (3 states per multiplicity), LumOrb for
*            triplet/singlet (orbital inheritance from quintet), CHOLESKY,
*            MOTRA run once on SCF orbitals, NEVPT2Prep + NEVPT2 per spin state.
*            MPSSI uses NrofJobIphs + QDSC + SpinOrbit + Ejob + Omega.
*            Crash: SIGSEGV in mps_rotate::rotate_mps at site 1 of triplet
*            rotation due to zero-norm first correction (small off-diagonal T
*            from LumOrb orbital inheritance) fixed by norm guard in mps_rotate.h.
*-------------------------------------------------------------------------------

>> RM -FORCE TEST_QCMAQUIS
>> IF ( $MOLCAS_DRIVER = UNKNOWN_VARIABLE )
>>   EXPORT MOLCAS_DRIVER=molcas
>> ENDIF
>> SHELL $MOLCAS_DRIVER have_feature qcmaquis || touch TEST_QCMAQUIS
>> IF ( -FILE TEST_QCMAQUIS )
>>   EXIT 36
>> ENDIF
&GATEWAY
coord
4
ang
H   0.0000000000   0.0000000000  -1.6450541782
C   0.0000000000   0.0000000000  -0.5832481605
C   0.0000000000   0.0000000000   0.5832481606
H   0.0000000000   0.0000000000   1.6450541782
basis=cc-pvdz
group=NOSYM
RICD
CDTH=1.0E-7
AMFI
ANGMOM
0.0 0.0 0.0
&SEWARD
&SCF
&MOTRA
Frozen=0
CTonly
Kpq
HDF5
* ====================================
* QUINTET (Spin=5) -- 3 states
* ====================================
&DMRGSCF
ActiveSpaceOptimizer=QCMaquis
DMRGSettings
  max_bond_dimension = 64
  nsweeps = 4
EndDMRGSettings
OOptimizationSettings
  Spin = 5
  nactel = 4,0,0
  inactive = 5
  RAS2 = 4
  CIRoot = 3 3 1
  NEVPT2Prep
EndOOptimizationSettings
&NEVPT2
States=3
>> COPY $Project.nevpt2.h5 $Project.quint.nevpt2.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.0.h5 $WorkDir/$Project.quint.nevpt2.checkpoint_state.0.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.1.h5 $WorkDir/$Project.quint.nevpt2.checkpoint_state.1.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.2.h5 $WorkDir/$Project.quint.nevpt2.checkpoint_state.2.h5
>> EXEC $MOLCAS/Tools/qcmaquis/qcm_checkpoint_rename.py $Project.quint.nevpt2.h5 -q
* ====================================
* TRIPLET (Spin=3) -- 3 states, LumOrb from quintet
* ====================================
&DMRGSCF
ActiveSpaceOptimizer=QCMaquis
DMRGSettings
  max_bond_dimension = 64
  nsweeps = 4
EndDMRGSettings
OOptimizationSettings
  Spin = 3
  nactel = 4,0,0
  inactive = 5
  RAS2 = 4
  CIRoot = 3 3 1
  NEVPT2Prep
  LumOrb
EndOOptimizationSettings
&NEVPT2
States=3
>> COPY $Project.nevpt2.h5 $Project.trip.nevpt2.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.0.h5 $WorkDir/$Project.trip.nevpt2.checkpoint_state.0.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.1.h5 $WorkDir/$Project.trip.nevpt2.checkpoint_state.1.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.2.h5 $WorkDir/$Project.trip.nevpt2.checkpoint_state.2.h5
>> EXEC $MOLCAS/Tools/qcmaquis/qcm_checkpoint_rename.py $Project.trip.nevpt2.h5 -q
* ====================================
* SINGLET (Spin=1) -- 3 states, LumOrb from quintet
* ====================================
&DMRGSCF
ActiveSpaceOptimizer=QCMaquis
DMRGSettings
  max_bond_dimension = 64
  nsweeps = 4
EndDMRGSettings
OOptimizationSettings
  Spin = 1
  nactel = 4,0,0
  inactive = 5
  RAS2 = 4
  CIRoot = 3 3 1
  NEVPT2Prep
  LumOrb
EndOOptimizationSettings
&NEVPT2
States=3
>> COPY $Project.nevpt2.h5 $Project.sing.nevpt2.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.0.h5 $WorkDir/$Project.sing.nevpt2.checkpoint_state.0.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.1.h5 $WorkDir/$Project.sing.nevpt2.checkpoint_state.1.h5
>> EXEC mv $WorkDir/$Project.checkpoint_state.2.h5 $WorkDir/$Project.sing.nevpt2.checkpoint_state.2.h5
>> EXEC $MOLCAS/Tools/qcmaquis/qcm_checkpoint_rename.py $Project.sing.nevpt2.h5 -q
>> COPY $Project.quint.nevpt2.h5 $Project.JobIph
>> COPY $Project.trip.nevpt2.h5 $Project.JobIph01
>> COPY $Project.sing.nevpt2.h5 $Project.JobIph02
* ====================================
* MPSSI: NEVPT2-dressed SO coupling (9 SO states: quintet x3 + triplet x3 + singlet x3)
* ====================================
&MPSSI
NrofJobIphs
3 3 3 3
1 2 3
1 2 3
1 2 3
QDSC
SpinOrbit
Ejob
Omega

>>FILE checkfile
* This file is autogenerated:
* Molcas version v25.10-146-g88ca4690c3
*

>>EOF
