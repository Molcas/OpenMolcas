*-------------------------------------------------------------------------------
* Molecule: CO
* Basis: cc-pVDZ
* Symmetry: none
* SCF: conventional
* Features tested: Localisation
* Comments:
*-------------------------------------------------------------------------------
>> RM -FORCE TEST_HDF5
>> IF ( $MOLCAS_DRIVER = UNKNOWN_VARIABLE )
>>   EXPORT MOLCAS_DRIVER=molcas
>> ENDIF
>> SHELL $MOLCAS_DRIVER have_feature hdf5 || touch TEST_HDF5
>> IF ( -FILE TEST_HDF5 )
>>   EXIT 36
>> ENDIF

&GATEWAY
  Coord = 2
    Bohr
    O 0.0 0.0 0.0
    C 0.0 0.0 2.132
  Basis = cc-pVDZ
  Group = NoSym
  NoCD

&SEWARD
  Cholesky

&SCF
  Title = CO, cc-pVDZ basis set
  Occupied = 7

> copy $Project.scf.h5 INPORB

* Default localisation, canonical orbitals
&LOCALISATION
  NOrb = 7
  LocCanOrb
    2 0.1
    O C

> rm INPORB

* Default localisation occupied/virtual orbitals
&LOCALISATION
  Occupied
  FileOrb = $Project.scf.h5

&LOCALISATION
  Virtual
  FileOrb = $Project.local.h5

* Other localisation methods
&LOCALISATION
  Boys
  FileOrb = $Project.scf.h5

&LOCALISATION
  PAO
  Threshold = 1.0d-14
  FileOrb = $Project.scf.h5

&LOCALISATION
  Edmiston-Ruedenberg
  Order
  FileOrb = $Project.scf.h5

&LOCALISATION
  Cholesky
  Freeze
  Domain
  FileOrb = $Project.scf.h5

