* This is not fully "converted" to HDF5:
*  SCF not reading initial orbitals from HDF5 (causes failure in ALASKA)
*  Reaction Vector is not available in HDF5 yet

>> RM -FORCE TEST_HDF5
>> IF ( $MOLCAS_DRIVER = UNKNOWN_VARIABLE )
>>   EXPORT MOLCAS_DRIVER=molcas
>> ENDIF
>> SHELL $MOLCAS_DRIVER have_feature hdf5 || touch TEST_HDF5
>> IF ( -FILE TEST_HDF5 )
>>   EXIT 36
>> ENDIF

&GATEWAY
  Coord = 3

    H  0.000  1.070  0.000
    C  0.000  0.000  0.000
    N  1.150  0.000  0.000
  Basis = STO-3G
  Group = NoSymm
  NoCD

>> DOWHILE

&SEWARD

&SCF

&SLAPAF
  FindTS
  TSConstraints
    d1 = bond H1 C2
    d2 = bond C2 N3
    a1 = angle H1 C2 N3
   Values
    d1 = 1.202 angstrom
    d2 = 1.222 angstrom
    a1 = 72.8 degree
  End of TSConstraints

>> ENDDO

>> COPY $Project.RunFile $Project.RunOld

&MCKINLEY

&GATEWAY
  Coord = $Project.slapaf.h5
  Basis = STO-3G
  Group = NoSymm
  NoCD

>> DOWHILE

&SEWARD

&SCF

&SLAPAF
  IRC
  nIRC = 4

>> ENDDO

